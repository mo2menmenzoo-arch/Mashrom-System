rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Fields: id (number), name (string), pin_code (string), role (string: Admin|Supervisor|Operator)
//
// Collection: partners
// Fields: id (number), name (string), share_percentage (number), total_payouts (number),
//         contribution_value (number), profit_percentage (number)
//
// Collection: greenhouses
// Fields: id (number), name (string), capacity (number), status (string: Active|Maintenance)
//
// Collection: cycles
// Fields: id (number), greenhouse_id (number), cycle_number (string), start_date (string),
//         end_date (string), status (string: Active|Completed), initial_investment (number)
//
// Collection: inventory
// Fields: id (number), date_added (string), item_name (string), quantity (number),
//         unit (string), expiry_date (string), min_stock_alert (number)
//
// Collection: petty_cash
// Fields: id (number), current_balance (number), last_updated (string)
//
// Collection: transactions
// Fields: id (number), timestamp (string), user_id (number), operation_type (string),
//         amount (number), balance_before (number), balance_after (number), details (string)
//
// Collection: expenses
// Fields: id (number), cycle_id (number), date (string), type (string: Operational|Selling),
//         details (string), amount (number), customer_name (string), paid_amount (number),
//         remaining_amount (number), total_amount (number), total_boxes (number),
//         price_per_box (number), linked_inventory_item_id (number), greenhouse_id (number),
//         due_date (string)
//
// Collection: operational_logs
// Fields: id (number), cycle_id (number), date (string), temperature (number),
//         humidity (number), co2_level (number), hygiene_status (string),
//         extra_notes (string), operator_id (number), harvest_weight (number),
//         harvest_type (string), harvest_grade (string)
//
// Collection: employees
// Fields: id (number), name (string), role (string), base_salary (number),
//         total_advances (number), total_bonuses (number), salary_type (string),
//         daily_rate (number), productivity_price_per_box (number)
//
// Collection: assets
// Fields: id (number), name (string), purchase_cost (number), purchase_date (string),
//         useful_life (number), accumulated_depreciation (number)
//
// Collection: production
// Fields: id (number), greenhouse_id (number), cycle_id (number), date (string),
//         weight (number), grade (string: A|B|C)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users — PINs are sensitive, only authenticated reads; writes only by matching user
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasOnly(['id','name','pin_code','role'])
        && request.resource.data.name is string
        && request.resource.data.pin_code is string
        && request.resource.data.role in ['Admin','Supervisor','Operator'];
      allow update: if isAuthenticated()
        && request.resource.data.keys().hasOnly(['id','name','pin_code','role'])
        && request.resource.data.role == resource.data.role;
      allow delete: if isAuthenticated();
    }

    // Partners
    match /partners/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Greenhouses
    match /greenhouses/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Cycles
    match /cycles/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Inventory
    match /inventory/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Petty cash — single document
    match /petty_cash/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Transactions — immutable audit trail
    match /transactions/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // No update or delete — transactions are immutable
    }

    // Expenses
    match /expenses/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Operational logs
    match /operational_logs/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Employees
    match /employees/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Assets
    match /assets/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Production
    match /production/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
