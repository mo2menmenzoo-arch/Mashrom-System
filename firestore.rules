rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Shared multi-device data: the app is a single shared workspace across all
    // phones. No per-user partitioning, no login. Open read/write to everyone so
    // data created on one phone appears on another.
    // ponytail: open by design — requested shared workspace. Tighten with a
    // workspace token later if access control is ever needed.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
