// نظام إدارة صوبة الماشروم — Prisma schema
// Inventory is a ledger: balance = sum(InventoryTxn.qty) where qty is signed.
// Every record must belong to a Cycle. Audit trail on every mutation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  OPERATOR
  ACCOUNTANT
}

enum CycleStatus {
  SCHEDULED
  ACTIVE
  ENDED
}

enum Cleanliness {
  EXCELLENT
  GOOD
  ACCEPTABLE
  POOR
}

enum InventorySource {
  DIRECT_PURCHASE
  OPERATING_EXPENSE
}

enum InventoryTxnType {
  IN
  OUT
  ADJUST
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  OVERRIDE
}

enum WithdrawalCategory {
  OPERATING
  FOUNDING
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?  // null for OAuth-only users
  role      Role     @default(OPERATOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  preferences    UserPreferences?

  accounts      Account[]
  auditLogs     AuditLog[]
  subscriptions PushSubscription[]
  createdCycles Cycle[]            @relation("CycleClosedBy")

  @@index([role, active])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Organization {
  id        String   @id @default(cuid())
  name      String   @default("الصوبة الرئيسية")
  createdAt DateTime @default(now())

  users             User[]
  financialSettings FinancialSettings?
  partners          Partner[]
  greenhouses       Greenhouse[]
}

model Greenhouse {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  number         Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  cycles           Cycle[]
  foundingExpenses FoundingExpense[]
  settings         GreenhouseSettings?

  @@unique([organizationId, number])
  @@index([organizationId])
}

model FoundingExpense {
  id           String     @id @default(cuid())
  greenhouseId String
  greenhouse   Greenhouse @relation(fields: [greenhouseId], references: [id])
  date         DateTime
  amount       Decimal    @db.Decimal(12, 2)
  description  String
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  custodyWithdrawalId String? @unique

  @@index([greenhouseId, date])
}

model Cycle {
  id           String      @id @default(cuid())
  greenhouseId String
  number       Int         @unique
  startDate    DateTime
  endDate      DateTime
  status       CycleStatus @default(SCHEDULED)
  closedAt     DateTime?
  closedById   String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  greenhouse  Greenhouse           @relation(fields: [greenhouseId], references: [id])
  closedBy    User?                @relation("CycleClosedBy", fields: [closedById], references: [id])
  expenses    Expense[]
  readings    OperationReading[]
  sales       Sale[]
  deposits    CustodyDeposit[]
  withdrawals CustodyWithdrawal[]
  inventory   InventoryItem[]

  @@index([status, startDate])
  @@index([greenhouseId])
}

model Expense {
  id          String   @id @default(cuid())
  cycleId     String
  date        DateTime
  description String
  amount      Decimal  @db.Decimal(12, 2)

  inventoryItemId String?        @unique
  inventoryItem   InventoryItem? @relation("ExpenseInventory", fields: [inventoryItemId], references: [id])

  cycle       Cycle    @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cycleId, date])
}

model InventoryItem {
  id         String          @id @default(cuid())
  cycleId    String
  name       String
  initialQty Decimal         @db.Decimal(12, 2)
  unit       String          @default("وحدة")
  expiryDate DateTime?
  source     InventorySource
  lowStockAt Decimal?        @db.Decimal(12, 2)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  cycle   Cycle          @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  expense Expense?       @relation("ExpenseInventory")
  txns    InventoryTxn[]

  @@index([cycleId, expiryDate])
  @@index([cycleId, name])
}

model InventoryTxn {
  id        String           @id @default(cuid())
  itemId    String
  type      InventoryTxnType
  qty       Decimal          @db.Decimal(12, 2) // signed: +IN, -OUT
  saleId    String?
  reason    String?
  createdAt DateTime         @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
  @@index([saleId])
}

model OperationReading {
  id          String       @id @default(cuid())
  cycleId     String
  date        DateTime
  dayNumber   Int
  temperature Decimal?     @db.Decimal(5, 2)
  humidity    Decimal?     @db.Decimal(5, 2)
  co2         Int?
  cleanliness Cleanliness?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Restrict)

  @@unique([cycleId, date])
  @@index([cycleId, dayNumber])
}

model Sale {
  id             String   @id @default(cuid())
  cycleId        String
  date           DateTime
  customerName   String
  cartons        Int
  pricePerCarton Decimal  @db.Decimal(10, 2)
  total          Decimal  @db.Decimal(12, 2)
  paid           Decimal  @db.Decimal(12, 2) @default(0)

  inventoryItemId String?

  cycle     Cycle    @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cycleId, date])
  @@index([customerName])
}

model CustodyDeposit {
  id        String   @id @default(cuid())
  cycleId   String
  date      DateTime
  amount    Decimal  @db.Decimal(12, 2)
  notes     String?
  cycle     Cycle    @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())

  @@index([cycleId, date])
}

model CustodyWithdrawal {
  id                String             @id @default(cuid())
  cycleId           String
  date              DateTime
  description       String
  amount            Decimal            @db.Decimal(12, 2)
  category          WithdrawalCategory @default(OPERATING)
  expenseId         String?            @unique
  foundingExpenseId String?            @unique
  cycle             Cycle              @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  createdAt         DateTime           @default(now())

  @@index([cycleId, date])
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String
  action    AuditAction
  entity    String
  entityId  String
  before    Json?
  after     Json?
  reason    String?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([entity, entityId])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GreenhouseSettings {
  id           String     @id @default(cuid())
  greenhouseId String     @unique
  greenhouse   Greenhouse @relation(fields: [greenhouseId], references: [id])
  temperature  Float      @default(22)
  humidity     Float      @default(85)
  cycleDuration Int       @default(60)
  updatedAt    DateTime   @updatedAt
}

model FinancialSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  currency       String       @default("EGP")
  taxRate        Float        @default(0)
  updatedAt      DateTime     @updatedAt
}

model Partner {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  sharePercent   Float
  position       Int          @default(0)
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, position])
}

model UserPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     String   @default("light")
  updatedAt DateTime @updatedAt
}
